# Copy to .env.local and fill in values.
# Supabase project URL — e.g. https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anon key — safe to ship to the browser (RLS enforces per-row access).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY. Used by sync scripts and server-side admin ops.
# Never prefix with NEXT_PUBLIC_ and never import admin.ts from a client component.
SUPABASE_SERVICE_ROLE_KEY=

# Dev-only auth bypass. When set to "1" AND NODE_ENV !== "production", the
# middleware mints a real Supabase session for tristan.fischer@gmail.com on
# every request and writes the session cookies on the response. Sub-agents
# doing parity screenshots can then hit /home, /tracker, /match, etc.
# without going through magic-link email. Belt-and-braces: both NODE_ENV
# and this flag must agree — production is always inert.
# DEV_SKIP_AUTH=1

# Anthropic API key — SERVER ONLY. Powers the "Draft with Haiku" buttons
# in the Templates section (/templates). When absent, the drafter action
# returns { ok: false, error: "ANTHROPIC_API_KEY not set — add to
# .env.local" } and the buttons are hidden on the page. Never prefix with
# NEXT_PUBLIC_. Model: claude-haiku-4-5-20251001 (cheap per-section
# drafting; swap the model id in app/(authed)/templates/actions.ts if
# you need a different Claude tier).
ANTHROPIC_API_KEY=

# Replicate API token — SERVER ONLY. Powers query-time semantic search on
# the Find-a-Match surface. When set, /lib/queries/match-score.ts embeds
# the founder's pitch via Replicate-hosted nomic-embed-text-v1.5 (the same
# 768-dim model the Forge Capital pipeline uses locally), then retrieves
# the top candidates via the `match_investors_by_embedding` Postgres RPC
# (pgvector HNSW cosine). When absent, the scorer falls back to the
# lexical pool — no error, just less relevant candidates. Get a token at
# https://replicate.com/account/api-tokens. Never prefix with NEXT_PUBLIC_.
REPLICATE_API_TOKEN=

