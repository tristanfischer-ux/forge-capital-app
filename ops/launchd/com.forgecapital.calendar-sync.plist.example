<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.forgecapital.calendar-sync</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/node</string>
        <string>/Users/tristanfischer/Developer/forge-capital-app/scripts/calendar-sync.mjs</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/tristanfischer/Developer/forge-capital-app</string>

    <key>StartInterval</key>
    <integer>600</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/private/tmp/fc-calendar-sync.log</string>

    <key>StandardErrorPath</key>
    <string>/private/tmp/fc-calendar-sync.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>NEXT_PUBLIC_SUPABASE_URL</key>
        <string><!-- PASTE YOUR NEXT_PUBLIC_SUPABASE_URL HERE --></string>

        <key>SUPABASE_SERVICE_ROLE_KEY</key>
        <string><!-- PASTE YOUR SUPABASE_SERVICE_ROLE_KEY HERE --></string>

        <key>GMAIL_CLIENT_ID</key>
        <string><!-- PASTE YOUR GMAIL_CLIENT_ID HERE --></string>

        <key>GMAIL_CLIENT_SECRET</key>
        <string><!-- PASTE YOUR GMAIL_CLIENT_SECRET HERE --></string>

        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
